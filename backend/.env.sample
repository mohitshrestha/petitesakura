# ============================================
# General Environment Configuration
# ============================================

# The environment the app is running in. Options: 'production', 'development', 'staging'.
APP_ENV=production

# Enable/Disable debugging mode. Set to 'true' during development.
DEBUG=false

# ============================================
# Google API Credentials
# ============================================

# Path to the Google OAuth client secret file (this is an example path)
GOOGLE_CLIENT_SECRET_PATH=backend/app/credentials/google/google-client-secret.json

# Path to the Google service account credentials file (if using service account authentication)
GOOGLE_SERVICE_ACCOUNT_PATH=backend/app/credentials/google/service-account.json

# Path to store the OAuth token file (this will be created dynamically after OAuth flow)
GOOGLE_TOKEN_PATH=backend/app/credentials/google/token.json

# ============================================
# Database Configuration
# ============================================

# Database connection string (use correct credentials in your local environment)
DATABASE_URL=postgres://user:password@localhost/dbname

# Secret key for cryptographic operations
SECRET_KEY=your-secret-key-here

# ============================================
# Third-party API Keys
# ============================================

# OpenAI API Key (you must replace this with your actual key when using OpenAI API)
OPENAI_API_KEY=your-openai-api-key-here
